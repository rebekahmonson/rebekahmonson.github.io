{# ===== BLOG PREVIEW ===== #}
{% set posts = collections.blog | limit(3) %}
{% if posts.length > 0 %}
<section class="section section--alt">
  <div class="container">
    <p class="section-label">From the blog</p>
    <h2 class="section-heading">Latest thoughts <span class="emoji-hover" data-animation="float">&#x270D;&#xFE0F;</span></h2>
    <div class="blog-grid">
      {% for post in posts %}
      <div class="blog-card">
        <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
        <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
        {% if post.data.excerpt %}<p>{{ post.data.excerpt }}</p>{% endif %}
      </div>
      {% endfor %}
    </div>
    <div class="blog-more">
      <a href="/blog/" class="btn btn--outline">View all posts</a>
    </div>
  </div>
</section>
{% endif %}


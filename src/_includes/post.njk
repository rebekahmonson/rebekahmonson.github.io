---
layout: base.njk
---
<article class="post">
  <div class="container container--narrow">
    <header class="post-header">
      <p class="post-meta">
        <time datetime="{{ page.date | isoDate }}">{{ page.date | readableDate }}</time>
      </p>
      <h1>{{ title }}</h1>
      {% if subtitle %}<p class="post-subtitle">{{ subtitle }}</p>{% endif %}
    </header>
    <div class="post-content prose">
      {{ content | safe }}
    </div>
    <footer class="post-footer">
      <a href="/blog/">&larr; Back to all posts</a>
    </footer>
  </div>
</article>
